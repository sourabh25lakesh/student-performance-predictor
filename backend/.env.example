# Copy this file to ".env" in the backend/ directory and fill in real values.
# Never commit your actual .env file to version control.

# ------------------------------------------------------------------
# General
# ------------------------------------------------------------------
ENVIRONMENT=development

APP_NAME=Student Performance Predictor
APP_VERSION=1.0.0
# ------------------------------------------------------------------
# MySQL Database
# Option A: set individual fields
# ------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=StrongPass@123
DB_NAME=student_performance_db

# Option B: OR set a single connection string (takes priority if set).
# Render/Railway typically inject something like this automatically.
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# ------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------
JWT_SECRET_KEY=replace_this_with_a_long_random_secret_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------
# CORS (comma-separated list is NOT supported directly by pydantic list
# parsing from .env; for multiple origins, prefer editing core/config.py
# defaults or passing a JSON array string, e.g. ["http://localhost:5500"])
# ------------------------------------------------------------------
CORS_ORIGINS=[http://localhost:5500"]

# ------------------------------------------------------------------
# ML Model
# ------------------------------------------------------------------
MODEL_PATH=app/ml/model.pkl
DATASET_PATH=../dataset/students.csv
PASS_MARKS=40


LOG_LEVEL=INFO
DEBUG=True

HOST=0.0.0.0
PORT=8000